# Copy to `.env` in the repo root (Murmur loads it automatically on CLI startup).

# --- Model provider (default: deepseek) ---
CHORUS_MODEL_PROVIDER=deepseek
CHORUS_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=

# V4 Pro reasoning + thinking (passed to chat.completions.create)
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING=enabled
DEEPSEEK_MAX_TOKENS=8192
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Agent task (default: hard) ---
# demo = echo uppercase smoke test | hard = full landing-site build
CHORUS_TASK=hard

# Anthropic (when CHORUS_MODEL_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=

# --- Murmur runtime ---
CHORUS_EVENT_LOG=.murmur/events.jsonl
CHORUS_TRACE_BACKEND=none
CHORUS_CAPTURE_CONTENT=false
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental

# LangSmith export (optional)
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=murmur
